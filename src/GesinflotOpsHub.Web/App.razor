<Router AppAssembly="@typeof(App).Assembly">
    <Found Context="routeData">
        <ErrorBoundary>
            <ChildContent>
                <AuthorizeRouteView RouteData="@routeData" DefaultLayout="@typeof(MainLayout)">
                    <NotAuthorized>
                        @if (context.User.Identity?.IsAuthenticated != true)
                        {
                            <RedirectToLogin />
                        }
                        else
                        {
                            <LayoutView Layout="@typeof(MainLayout)">
                                <p class="text-danger" style="padding:24px">No tiene permisos para acceder a esta sección.</p>
                            </LayoutView>
                        }
                    </NotAuthorized>
                </AuthorizeRouteView>
            </ChildContent>
            <ErrorContent Context="ex">
                <LayoutView Layout="@typeof(MainLayout)">
                    <div style="padding:24px">
                        <h3>Se ha producido un error</h3>
                        <p>@ex.Message</p>
                        <a href="/">Volver al inicio</a>
                    </div>
                </LayoutView>
            </ErrorContent>
        </ErrorBoundary>
        <FocusOnNavigate RouteData="@routeData" Selector="h1" />
    </Found>
    <NotFound>
        <PageTitle>Página no encontrada — Gesinflot</PageTitle>
        <LayoutView Layout="@typeof(MainLayout)">
            <h2>Página no encontrada (404)</h2>
            <a href="/">Volver al inicio</a>
        </LayoutView>
    </NotFound>
</Router>
