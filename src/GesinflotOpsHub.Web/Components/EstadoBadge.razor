@namespace GesinflotOpsHub.Web.Components

<span class="badge estado-badge estado-@NormalizeEstado(Estado ?? Tipo)">@(Estado ?? Tipo)</span>

@code {
    [Parameter] public string? Estado { get; set; }
    [Parameter] public string Tipo { get; set; } = "";

    private static string NormalizeEstado(string? s)
        => (s ?? "").ToLowerInvariant().Replace(" ", "-");
}
