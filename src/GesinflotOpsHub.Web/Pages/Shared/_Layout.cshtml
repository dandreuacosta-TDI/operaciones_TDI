@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Gesinflot Ops Hub</title>
    <link rel="stylesheet" href="~/css/app.css" asp-append-version="true" />
</head>
<body class="auth-page">
    <div class="auth-container">
        <div class="auth-logo-wrap">
            <div class="auth-logo-icon" style="width:52px;height:52px;background:#1d4ed8;border-radius:12px;display:flex;align-items:center;justify-content:center;margin:0 auto 12px;">
                <span style="color:white;font-size:22px;font-weight:700;">G</span>
            </div>
            <div class="auth-brand-name">Gesinflot</div>
            <div class="auth-brand-sub">Operations Hub</div>
        </div>
        @RenderBody()
    </div>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
