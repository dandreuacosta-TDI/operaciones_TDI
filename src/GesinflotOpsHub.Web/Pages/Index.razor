@page "/"
@attribute [Authorize]
@inject IIntervencionService IntervencionService
@using GesinflotOpsHub.Application.DTOs
@using GesinflotOpsHub.Application.Services
@using Microsoft.AspNetCore.Authorization

<PageTitle>Dashboard — Gesinflot Ops Hub</PageTitle>

<h1 class="page-title">📊 Dashboard Operativo</h1>

@if (_kpis is null)
{
    <p class="loading">Cargando KPIs...</p>
}
else
{
    <div class="kpi-grid">
        <KpiCard Title="Expedientes activos" Value="@_kpis.ExpedientesActivos.ToString()" Icon="📁" Color="blue" />
        <KpiCard Title="Instalaciones pendientes" Value="@_kpis.InstalacionesPendientes.ToString()" Icon="📅" Color="orange" />
        <KpiCard Title="Intervenciones este mes" Value="@_kpis.IntervencionesEstesMes.ToString()" Icon="🔧" Color="green" />
        <KpiCard Title="Checklists pendientes" Value="@_kpis.ChecklistsPendientes.ToString()" Icon="✅" Color="yellow" />
        <KpiCard Title="Facturación del mes" Value="@_kpis.FacturacionMes.ToString("N0") + " €"" Icon="💶" Color="teal" />
        <KpiCard Title="Facturación acumulada" Value="@_kpis.FacturacionAcumulada.ToString("N0") + " €"" Icon="📈" Color="purple" />
        <KpiCard Title="Margen medio" Value="@_kpis.MargenMedio.ToString("N1") + " %"" Icon="📉" Color="red" />
        <KpiCard Title="Intervenciones realizadas" Value="@_kpis.IntervencionesRealizadas.ToString()" Icon="✔️" Color="green" />
    </div>

    <div class="dashboard-section">
        <h3>Intervenciones por tipo</h3>
        <div class="chart-bar-list">
            @foreach (var kv in _kpis.IntervencionesiPorTipo.OrderByDescending(x => x.Value))
            {
                <div class="bar-row">
                    <span class="bar-label">@kv.Key</span>
                    <div class="bar" style="width:@(kv.Value * 20)px">@kv.Value</div>
                </div>
            }
        </div>
    </div>

    <div class="dashboard-section">
        <h3>Facturación por comercial</h3>
        <table class="table table-sm">
            <thead><tr><th>Comercial</th><th class="text-end">Importe</th></tr></thead>
            <tbody>
                @foreach (var kv in _kpis.FacturacionPorComercial.OrderByDescending(x => x.Value))
                {
                    <tr>
                        <td>@kv.Key</td>
                        <td class="text-end">@kv.Value.ToString("N0") €</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@code {
    private KpiOperacionesDto? _kpis;

    protected override async Task OnInitializedAsync()
    {
        _kpis = await IntervencionService.GetKpisAsync(null, null);
    }
}
